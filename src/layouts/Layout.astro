---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Bewick Carpentry",
  description = "Quality carpentry serving the Greater Victoria area. Outdoor structures, renovations, repairs, and more. Craftsmanship is everything."
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Rye&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <link rel="icon" href="/images/logo.png" />
    <title>{title}</title>
  </head>
  <body class="bg-coal text-cream font-body overflow-x-hidden">
    <slot />
  </body>
</html>
